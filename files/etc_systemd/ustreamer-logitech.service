[Unit]
Description=uStreamer - Logitech QuickCam Pro 5000
After=network.target

[Service]
ExecStart=/usr/bin/ustreamer \
  --device /dev/video0 \
  --resolution 640x480 \
  --format mjpeg \
  --desired-fps 30 \
  --persistent \
  --slowdown \
  --drop-same-frames 30 \
  --host 0.0.0.0 \
  --port 8080 \
  --allow-origin "*"
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
