# Rate limiting zone: 10 requests/second per IP
limit_req_zone $binary_remote_addr zone=auth_limit:10m rate=10r/s;
limit_req_status 429;

# HTTP — redirect everything to HTTPS
server {
    listen 80 default_server;
    server_name _;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS — main site with session-based auth
server {
    listen 443 ssl default_server;
    server_name wansteadcam.lumoco.com;

    ssl_certificate /etc/letsencrypt/live/wansteadcam.lumoco.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/wansteadcam.lumoco.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # HSTS — force HTTPS for returning visitors (1 year, include subdomains)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    root /var/www/camviewer;
    index index.html;

    # Internal auth subrequest — proxies to Flask backend
    location = /internal/auth {
        internal;
        proxy_pass http://127.0.0.1:8086/api/verify;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header X-Original-URI $request_uri;
    }

    # Public: login page — no cache to prevent stale login page after auth
    location = /login.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma "no-cache";
        add_header Expires "0";
        try_files $uri =404;
    }

    # Public: logo and static assets
    location = /WansteadCam.png {
        try_files $uri =404;
    }

    # Public: auth API endpoints (proxied to Flask)
    location /api/ {
        limit_req zone=auth_limit burst=20 nodelay;
        proxy_pass http://127.0.0.1:8086;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Public: Let's Encrypt challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Protected: dashboard — require valid session
    location / {
        auth_request /internal/auth;
        auth_request_set $auth_user $upstream_http_x_auth_user;
        error_page 401 = /login.html;

        limit_req zone=auth_limit burst=20 nodelay;
        try_files $uri $uri/ =404;
    }

    # Protected: Sweex still image
    location = /sweex_latest.jpg {
        auth_request /internal/auth;
        error_page 401 = /login.html;

        limit_req zone=auth_limit burst=20 nodelay;
        add_header Cache-Control "no-cache, no-store";
        try_files $uri =404;
    }

    # Protected: Logitech MJPEG stream (no rate limiting — long-lived connection)
    location /stream/logitech/ {
        auth_request /internal/auth;
        error_page 401 = /login.html;

        proxy_pass http://127.0.0.1:8080/stream;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_set_header Connection '';
        proxy_http_version 1.1;
        chunked_transfer_encoding off;
    }

    # Protected: WebSocket MJPEG relay for Safari/iOS (no rate limiting — long-lived connection)
    location /ws/logitech/ {
        auth_request /internal/auth;
        error_page 401 = /login.html;

        proxy_pass http://127.0.0.1:8087/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}

# LAN-only — no auth, port 8085
server {
    listen 8085;
    server_name _;

    root /var/www/camviewer;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location = /sweex_latest.jpg {
        add_header Cache-Control "no-cache, no-store";
        try_files $uri =404;
    }

    location /stream/logitech/ {
        proxy_pass http://127.0.0.1:8080/stream;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_set_header Connection '';
        proxy_http_version 1.1;
        chunked_transfer_encoding off;
    }

    location /ws/logitech/ {
        proxy_pass http://127.0.0.1:8087/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
